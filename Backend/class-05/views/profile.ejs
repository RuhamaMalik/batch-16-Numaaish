<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile Page</title>
</head>

<body>

  <h1> User Profile</h1>

  <img width="300" src="<%= user.image %>" alt="">
  <ul>
    <li>Name : <%= user.name %>
    </li>
    <li>Email : <%= user.email %>
    </li>
    <li>Contact : <%= user.contact %>
    </li>
    <li>Address : <%= user.Address %>
    </li>


    <!--   <%  %>      -->


    <% if (user.experience> 2) { %>
      <li>Senior</li>
      <%} else {%>
        <li>Junior</li>
        <%} %>

  </ul>


  <h3>Skills</h3>

  <ul>
    <% user.skills.forEach(skill=> { %>
      <li><%= skill %></li>
      <% }); %>
  </ul>

</body>

</html>